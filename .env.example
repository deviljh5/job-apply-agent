# Database (SQLite for dev, PostgreSQL for prod)
# For free Vercel + Neon deployment, use: postgresql://username:password@host.neon.tech/database?sslmode=require
DATABASE_URL="file:./dev.db"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="demo-secret-key-change-for-production"

# Google OAuth (Required for login - free to create)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# AI Provider (Optional - leave as "your-openai-api-key" for free demo mode)
# Demo mode generates mock AI responses without API calls
# For real AI: https://platform.openai.com/api-keys
OPENAI_API_KEY="your-openai-api-key"

# Gmail API (Optional - for email sync, uses same Google OAuth credentials)
GMAIL_CLIENT_ID="your-gmail-client-id"
GMAIL_CLIENT_SECRET="your-gmail-client-secret"
GMAIL_REDIRECT_URI="http://localhost:3000/api/auth/callback/google"

# Adzuna API (Optional - for real job aggregation)
# Get from: https://developer.adzuna.com/
ADZUNA_APP_ID="your-adzuna-app-id"
ADZUNA_API_KEY="your-adzuna-api-key"

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
API_BASE_URL="http://localhost:3000"
